{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "snap",
  "version": "0.1.0",
  "identifier": "com.adjective.snap",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "overlay",
        "title": "Snap",
        "visible": false,
        "transparent": false,
        "decorations": false,
        "fullscreen": false,
        "width": 1920,
        "height": 1080,
        "x": 0,
        "y": 0,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["/tmp/snap-*"],
          "deny": []
        }
      },
      "csp": null
    }
  },
  "plugins": {}
}
