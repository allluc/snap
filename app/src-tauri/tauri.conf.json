{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "snap",
  "version": "0.1.0",
  "identifier": "com.adjective.snap",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [],
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["/tmp/snap-*", "/private/tmp/snap-*"],
          "deny": []
        }
      },
      "csp": null
    }
  },
  "plugins": {},
  "bundle": {}
}
